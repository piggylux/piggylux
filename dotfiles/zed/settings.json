// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "title_bar": {
    "show_menus": false,
  },
  "diff_view_style": "split",
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte",
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "search": {
    "center_on_match": true,
    "button": false,
  },
  "inline_code_actions": false,
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "agent_servers": {},
  "buffer_line_height": "standard",
  "edit_predictions": {
    "provider": "none",
  },
  "word_diff_enabled": true,
  "project_panel": {
    "dock": "right",
    "sticky_scroll": false,
    "git_status": true,
  },
  "cursor_blink": true,
  "cursor_shape": "bar",
  "git_panel": {
    "folder_icons": true,
    "file_icons": true,
    "button": true,
    "status_style": "label_color",
    "tree_view": false,
    "collapse_untracked_diff": false,
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },
  "agent": {
    "button": false,
    "sidebar_side": "right",
    "dock": null,
    "default_model": {
      "provider": "openai",
      "model": "gpt-5",
    },
  },
  "file_types": {
    "HTML": ["html"],
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "angular": "html",
        },
        "classAttributes": ["class", "className", "ngClass", "[class]"],
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "\\[class\\]=\"([^\"]*)\"",
            "\\[class\\]='([^']*)'",
            "\\[ngClass\\]=\"([^\"]*)\"",
            "\\[ngClass\\]='([^']*)'",
          ],
        },
      },
    },
    "pyright": {
      "settings": {},
    },
  },
  "languages": {
    "Python": {
      "language_servers": ["!ty", "!basedpyright", "pyright", "ruff", "..."],
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": { "name": "ruff" },
        },
      ],
    },
    "HTML": {
      "language_servers": ["angular", "tailwindcss-language-server", "..."],
      "format_on_save": "on",
    },
    "SCSS": {
      "language_servers": ["!some-sass-lsp", "stylelint-lsp", "scss-lsp"],
    },
    "TypeScript": {
      "language_servers": [
        "typescript-language-server",
        "tailwindcss-language-server",
        "angular",
      ],
      "formatter": [
        {
          "external": {
            "command": "./node_modules/.bin/biome",
            "arguments": [
              "format",
              "--write",
              "--stdin-file-path={buffer_path}",
            ],
          },
        },
      ],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Angular": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },
  "theme": {
    "mode": "light",
    "light": "Catppuccin Latte (Blur)",
    "dark": "Catppuccin Mocha (Blur)",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "tab_size": 2,
  "base_keymap": "JetBrains",
  "buffer_font_family": "IBM Plex Mono",
  "buffer_font_weight": 399,
  // "ui_font_family": "IBM Plex Mono",
  // "buffer_font_size": 14,
  // "buffer_font_family": "Cascadia Code",
  "terminal": {
    "flexible": true,
    "font_family": "MesloLGS NF",
    "font_fallbacks": ["MesloLGS NF"],
    "line_height": "standard",
    "font_size": 14,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": null, // same values as the `diagnostics_max_severity` from the editor settings
    },
  },
  "auto_install_extensions": {
    "html": true,
    "catppuccin-blur": true,
    "catppuccin": true,
    "dockerfile": true,
    "emmet": true,
    "scss": true,
    "biome": true,
    "docker-compose": true,
    "pylsp": true,
    "python-requirements": true,
    "angular": true,
    "stylelint": true,
    "pytest-language-server": true,
  },
